name: Otomatik WordPress Blog Botu

on:
  schedule:
    # ABD Doğu Saati (EDT - Yaz Saati) baz alınarak: 
    # Akşam 6 (18:00 EDT -> 22:00 UTC)
    # Gece 10 (22:00 EDT -> 02:00 UTC)
    - cron: '0 2,22 * * *'
  workflow_dispatch: # Manuel çalıştırma butonu

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - name: Kodlari Cek
        uses: actions/checkout@v4

      - name: Python Kur
        uses: actions/setup-python@v5
        with:
          python-version: '3.10'

      - name: Kutuphaneleri Yukle
        run: |
          pip install google-genai requests

      - name: Scripti Calistir
        run: python main.py
